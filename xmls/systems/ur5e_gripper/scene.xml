<mujoco model="6dof_gripper_scene">
  <include file="fr_arm_with_hand.xml"/>

  <statistic center="0.2 0 0.3" extent="0.8"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.1 0.1 0.1" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="120" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge"
      rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3" markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <!-- 그래스핑 대상: 박스 -->
    <body name="target_object" pos="-0.10 0.25 0.05">
      <joint type="free"/>
      <geom size="0.04 0.04 0.05" type="box"
          density="500" friction="1 0.005 0.0001" rgba="1 0.2 0.2 1"/>
    </body>

    <!-- 구 -->
    <body name="sphere_object" pos="0.10 0.25 0.03">
      <joint type="free"/>
      <geom size="0.03" type="sphere"
          density="500" friction="1 0.005 0.0001" rgba="0.2 0.6 1 1"/>
    </body>

    <!-- 빨간 구 -->
    <body name="red_sphere" pos="-0.05 0.30 0.03">
      <joint type="free"/>
      <geom size="0.03" type="sphere"
          density="500" friction="1 0.005 0.0001" rgba="1 0.2 0.2 1"/>
    </body>
  </worldbody>
</mujoco>
